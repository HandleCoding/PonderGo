{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "hawkeye"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-kill"
  ]
}
